# Copy to .env and fill in. Backend reads these with the OPE_ prefix.

# self_host | hosted. self_host enables single-user conveniences (e.g. header paste).
OPE_DEPLOYMENT_MODE=self_host
OPE_FRONTEND_URL=http://localhost:8080

# Encryption key for stored provider credentials. CHANGE THIS.
OPE_SECRET_KEY=change-me-please

# Youtube Music OAuth app (https://console.cloud.google.com/apis/credentials)
# Important: leave empty until the app is approved for prod use, this makes the app use 
# a dev token from the header paste flow instead of the OAuth flow. 
# This is a temporary measure until the app is approved.
OPE_YTMUSIC_ENABLED=true
OPE_YOUTUBE_OFFICIAL_ENABLED=false
OPE_YTMUSIC_CLIENT_ID=
OPE_YTMUSIC_CLIENT_SECRET=
# Used to match reconnected YouTube Music accounts by Google email when available.
OPE_YTMUSIC_USERINFO_URL=https://www.googleapis.com/oauth2/v2/userinfo

# Matching
OPE_REVIEW_CONFIDENCE_THRESHOLD=0.8
OPE_ENABLE_SHARED_GRAPH=false

# Conservative migration guardrails; the UI can override after a warning.
OPE_MIGRATION_SAFE_MAX_PLAYLISTS_PER_JOB=1
OPE_MIGRATION_SAFE_MAX_TRACKS_PER_JOB=50
OPE_MIGRATION_SAFE_DAILY_TRACKS=250
OPE_MIGRATION_SAFE_MIN_JOB_GAP_S=120
# ARQ worker timeout for one migration job. Large Spotify playlists can exceed 5 minutes.
OPE_MIGRATION_WORKER_JOB_TIMEOUT_S=3600

# Public URL and pasted-text imports
OPE_IMPORT_MAX_TEXT_BYTES=262144
OPE_IMPORT_MAX_ITEMS=1000
OPE_IMPORT_MAX_LINE_CHARS=2000
OPE_IMPORT_MAX_FIELD_CHARS=500
OPE_IMPORT_MAX_URL_CHARS=2048
OPE_IMPORT_MAX_RESPONSE_BYTES=2000000
OPE_IMPORT_MAX_REDIRECTS=3
OPE_IMPORT_HTTP_TIMEOUT_S=10
# Comma-separated public HTTPS hosts allowed to serve Open Playlist Engine shares.
# A public HTTPS OPE_FRONTEND_URL host is included automatically.
OPE_IMPORT_OPEN_PLAYLIST_HOSTS=

# Spotify OAuth app (https://developer.spotify.com/dashboard)
OPE_SPOTIFY_CLIENT_ID=
OPE_SPOTIFY_CLIENT_SECRET=
OPE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/api/auth/spotify/callback

# Tidal OAuth app (https://developer.tidal.com)
OPE_TIDAL_CLIENT_ID=
OPE_TIDAL_CLIENT_SECRET=
OPE_TIDAL_REDIRECT_URI=http://127.0.0.1:8000/api/auth/tidal/callback

# Apple MusicKit (https://developer.apple.com/help/account/capabilities/create-a-media-identifier-and-private-key/)
# Apple Music does not use OAuth client ID/client secret credentials.
OPE_APPLE_MUSIC_TEAM_ID=
OPE_APPLE_MUSIC_KEY_ID=
# Prefer a path for local development, or use an escaped PEM value in OPE_APPLE_MUSIC_PRIVATE_KEY.
OPE_APPLE_MUSIC_PRIVATE_KEY_PATH=
OPE_APPLE_MUSIC_PRIVATE_KEY=
OPE_APPLE_MUSIC_TOKEN_TTL_S=86400
